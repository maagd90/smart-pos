# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/

# ── Environment files (never commit secrets) ──────────────────────────────────
.env
.env.local
.env.*.local
# Keep example files
!.env.example

# ── Build outputs ─────────────────────────────────────────────────────────────
dist/
build/
out/

# ── TypeScript compiled output ────────────────────────────────────────────────
*.js.map
*.d.ts.map

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# ── OS generated ──────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── IDE / editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Testing ───────────────────────────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov

# ── Prisma ────────────────────────────────────────────────────────────────────
prisma/.cache
# Keep migration files and schema
!prisma/migrations/
!prisma/schema.prisma

# ── Docker ────────────────────────────────────────────────────────────────────
.docker/

# ── Miscellaneous ─────────────────────────────────────────────────────────────
.cache/
.parcel-cache/
.turbo/
.eslintcache
.stylelintcache
*.tgz
*.zip
